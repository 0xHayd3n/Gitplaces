{
  "name": "git-suite",
  "version": "0.1.0",
  "description": "Git Suite — GitHub repo skill manager",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "posttest": "npx @electron/rebuild -f -o better-sqlite3",
    "postinstall": "npx @electron/rebuild -f -o better-sqlite3",
    "vendor:node22": "node scripts/fetch-node22.mjs",
    "vendor:anatomy": "git submodule update --init --recursive && node scripts/build-anatomy.mjs",
    "vendor": "npm run vendor:node22 && npm run vendor:anatomy"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
